# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT={{APP_PORT}}

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN={{DOMAIN}}

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/{{APP_NAME}}_prod

# ── Auth / Secrets ───────────────────────────────────────────────────────────
# SESSION_SECRET=replace-with-a-long-random-string
# JWT_SECRET=replace-with-a-long-random-string

# ── Email ────────────────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── External APIs ────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
